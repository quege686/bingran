<style>
:root {
  --primary: #1a1a2e;
  --accent: #e94560;
  --secondary: #16213e;
  --light: #f8f9fa;
  --gray: #6c757d;
  --border: #dee2e6;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
  background: #f0f2f5;
  color: #333;
  line-height: 1.8;
}
/* Nav */
.nav-sidebar {
  position: fixed;
  left: 0; top: 0;
  width: 220px; height: 100vh;
  background: var(--primary);
  overflow-y: auto;
  z-index: 100;
  padding: 20px 0;
}
.nav-sidebar h2 {
  color: #fff;
  font-size: 16px;
  padding: 0 20px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  margin-bottom: 10px;
}
.nav-sidebar a {
  display: block;
  color: rgba(255,255,255,0.7);
  text-decoration: none;
  padding: 10px 20px;
  font-size: 14px;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}
.nav-sidebar a:hover {
  color: #fff;
  background: rgba(255,255,255,0.05);
  border-left-color: var(--accent);
}
.nav-sidebar a.sub {
  padding-left: 36px;
  font-size: 13px;
}
/* Main */
.main-content {
  margin-left: 220px;
  padding: 0;
}
/* Hero */
.hero {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #fff;
  padding: 80px 40px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -50%; right: -20%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(233,69,96,0.1) 0%, transparent 70%);
  border-radius: 50%;
}
.hero h1 {
  font-size: 42px;
  font-weight: 700;
  letter-spacing: 4px;
  margin-bottom: 16px;
  position: relative;
}
.hero .subtitle {
  font-size: 16px;
  color: rgba(255,255,255,0.6);
  letter-spacing: 8px;
  text-transform: uppercase;
  position: relative;
}
.hero .meta {
  margin-top: 30px;
  font-size: 14px;
  color: rgba(255,255,255,0.4);
}
/* Section */
.section {
  background: #fff;
  margin: 30px 40px;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  overflow: hidden;
}
.section-header {
  padding: 40px 40px 30px;
  position: relative;
}
.section-header .trend-tag {
  display: inline-block;
  font-size: 12px;
  letter-spacing: 4px;
  color: var(--accent);
  text-transform: uppercase;
  margin-bottom: 12px;
  font-weight: 600;
}
.section-header h2 {
  font-size: 32px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 16px;
}
.section-header .desc {
  font-size: 15px;
  color: var(--gray);
  max-width: 700px;
  line-height: 2;
}
.section-header .path {
  margin-top: 12px;
  font-size: 13px;
  color: var(--gray);
  background: var(--light);
  padding: 8px 16px;
  border-radius: 8px;
  display: inline-block;
}
/* Cards Grid */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 20px;
  padding: 0 40px 40px;
}
.card {
  background: var(--light);
  border-radius: 12px;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid var(--border);
}
.card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.1);
}
.card-header {
  padding: 20px 20px 12px;
}
.card-header .card-title {
  font-size: 17px;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 6px;
}
.card-header .card-path {
  font-size: 12px;
  color: var(--gray);
}
.card-body {
  padding: 0 20px 20px;
}
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}
.tag {
  display: inline-block;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 500;
}
.tag.red { background: #fce4ec; color: #c62828; }
.tag.blue { background: #e3f2fd; color: #1565c0; }
.tag.green { background: #e8f5e9; color: #2e7d32; }
.tag.orange { background: #fff3e0; color: #e65100; }
.tag.purple { background: #f3e5f5; color: #6a1b9a; }
.tag.teal { background: #e0f2f1; color: #00695c; }
.tag.gray { background: #eceff1; color: #455a64; }
.tag.pink { background: #fce4ec; color: #ad1457; }
/* Trend Section */
.trend-box {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 30px 40px;
  margin: 0 40px 30px;
  border-radius: 12px;
}
.trend-box h3 {
  font-size: 18px;
  margin-bottom: 12px;
}
.trend-box p {
  font-size: 15px;
  line-height: 2;
  opacity: 0.95;
}
/* Summary Box */
.summary-box {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  padding: 30px 40px;
  margin: 0 40px 30px;
  border-radius: 12px;
  border-left: 4px solid var(--accent);
}
.summary-box h3 {
  font-size: 20px;
  color: var(--primary);
  margin-bottom: 12px;
}
.summary-box p {
  font-size: 15px;
  color: #444;
  line-height: 2;
}
/* Color Palette */
.color-palette {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  padding: 0 40px 40px;
}
.color-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  padding: 8px 16px;
  border-radius: 8px;
  border: 1px solid var(--border);
  font-size: 14px;
}
.color-dot {
  width: 20px; height: 20px;
  border-radius: 50%;
  flex-shrink: 0;
}
/* Page indicator */
.page-num {
  position: absolute;
  top: 20px; right: 20px;
  font-size: 12px;
  color: var(--gray);
  background: var(--light);
  padding: 4px 10px;
  border-radius: 4px;
}
/* Note box */
.note-box {
  background: #fff3cd;
  border: 1px solid #ffeaa7;
  border-radius: 8px;
  padding: 12px 16px;
  margin: 10px 40px 10px;
  font-size: 14px;
  color: #856404;
}
.note-box strong { color: #d63200; }
/* Timeline */
.timeline-tag {
  display: inline-block;
  background: var(--accent);
  color: #fff;
  padding: 4px 14px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  margin: 4px 0;
}
/* Footer */
.footer {
  text-align: center;
  padding: 40px;
  color: var(--gray);
  font-size: 14px;
}
/* Category Divider */
.category-divider {
  display: flex;
  align-items: center;
  gap: 16px;
  margin: 40px 40px 20px;
}
.category-divider .line {
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, var(--accent), transparent);
}
.category-divider .num {
  font-size: 48px;
  font-weight: 800;
  color: var(--accent);
  opacity: 0.15;
}
/* Responsive */
@media (max-width: 768px) {
  .nav-sidebar { display: none; }
  .main-content { margin-left: 0; }
  .section, .trend-box, .summary-box, .note-box { margin-left: 16px; margin-right: 16px; }
  .cards-grid { grid-template-columns: 1fr; padding: 0 16px 20px; }
  .hero { padding: 50px 20px; }
  .hero h1 { font-size: 28px; }
}
</style>
